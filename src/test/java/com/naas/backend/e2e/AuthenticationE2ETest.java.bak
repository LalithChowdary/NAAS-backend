package com.naas.backend.e2e;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.openqa.selenium.By;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.ui.ExpectedConditions;

import static org.junit.jupiter.api.Assertions.*;

/**
 * E2E Tests for Authentication & Session Management — Suite 1
 *
 * SRS Coverage:
 *   FR-AU2: Credential verification before access is granted.
 *   FR-AU3: Role-based access restriction on each portal.
 *   FR-AU6: Error messages shown for failed login attempts.
 *
 * Run command:
 *   ./mvnw test -Dgroups=e2e
 *
 * Prerequisites: Both Next.js (port 3000) and Spring Boot (port 8080)
 * must be running before executing these tests.
 */
@Tag("e2e")
class AuthenticationE2ETest extends BaseSeleniumTest {

    // ── Helper: performs the login flow ──────────────────────────────────────
    private void performLogin(String email, String password) {
        driver.get(BASE_URL + "/login");

        // Wait for the email input to be visible and interactable
        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.cssSelector("[data-testid='login-email']")));

        driver.findElement(By.cssSelector("[data-testid='login-email']"))
              .sendKeys(email);
        driver.findElement(By.cssSelector("[data-testid='login-password']"))
              .sendKeys(password);
        driver.findElement(By.cssSelector("[data-testid='login-submit']"))
              .click();
        try { Thread.sleep(2000); } catch (Exception e) {}
    }

    // ── Test 1: Valid Customer Login (FR-AU2 / FR-AU3) ──────────────────────

    @Test
    @DisplayName("E2E-AU-1: Valid customer credentials should redirect to /customer dashboard")
    void validCustomerLogin_shouldRedirectToDashboard() {
        // Act — perform login with correct credentials
        performLogin(CUSTOMER_EMAIL, CUSTOMER_PASSWORD);

        // Assert (1) — URL contains "/customer" (redirect successful)
        wait.until(ExpectedConditions.urlContains("/customer"));
        assertTrue(driver.getCurrentUrl().contains("/customer"),
                "Expected URL to contain '/customer' after successful login");

        // Assert (2) — The customer dashboard element is rendered on screen
        WebElement dashboard = wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.cssSelector("[data-testid='customer-dashboard']")));
        assertTrue(dashboard.isDisplayed(),
                "Expected 'customer-dashboard' element to be visible after login");
    }

    // ── Test 2: Invalid Login Rejection (FR-AU6) ─────────────────────────────

    @Test
    @DisplayName("E2E-AU-2: Wrong password should show error message and stay on /login")
    void invalidLogin_shouldShowErrorMessage() {
        // Act — submit form with wrong password
        performLogin(CUSTOMER_EMAIL, "totally-wrong-password");

        // Assert (1) — Wait for the error banner to appear
        WebElement errorMsg = wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.cssSelector("[data-testid='login-error-msg']")));
        assertTrue(errorMsg.isDisplayed(),
                "Expected login error message to be visible");

        // Assert (2) — The error text contains the expected message
        assertTrue(errorMsg.getText().toLowerCase().contains("invalid"),
                "Expected error text to contain 'invalid'");

        // Assert (3) — We must still be on the login page (no redirect)
        assertTrue(driver.getCurrentUrl().contains("/login"),
                "Expected to remain on the /login page after failed login");
    }

    // ── Test 3: Logout Flow ───────────────────────────────────────────────────

    @Test
    @DisplayName("E2E-AU-3: Clicking logout should clear session and redirect to /login")
    void logout_shouldRedirectToLoginPage() {
        // Arrange — log in first
        performLogin(CUSTOMER_EMAIL, CUSTOMER_PASSWORD);
        wait.until(ExpectedConditions.urlContains("/customer"));

        // Act — click the logout button
        WebElement logoutBtn = wait.until(ExpectedConditions.elementToBeClickable(
                By.cssSelector("[data-testid='logout-btn']")));
        logoutBtn.click();

        // Assert — redirected back to the login page
        wait.until(ExpectedConditions.urlContains("/login"));
        assertTrue(driver.getCurrentUrl().contains("/login"),
                "Expected URL to redirect to /login after logout");

        // Assert — login page elements are visible (not dashboard)
        assertTrue(
                driver.findElement(By.cssSelector("[data-testid='login-email']")).isDisplayed(),
                "Expected login email input to be visible after logout"
        );
    }

    // ── Test 4: Session Persistence after Page Refresh ───────────────────────

    @Test
    @DisplayName("E2E-AU-4: User should remain logged in after a full page refresh")
    void sessionPersistence_shouldKeepUserLoggedInAfterRefresh() {
        // Arrange — log in successfully
        performLogin(CUSTOMER_EMAIL, CUSTOMER_PASSWORD);
        wait.until(ExpectedConditions.urlContains("/customer"));

        // Act — force a full browser page reload
        driver.navigate().refresh();

        // Assert — After reload, still on /customer and dashboard is visible
        // We wait for the dashboard element to reappear (server component re-renders)
        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.cssSelector("[data-testid='customer-dashboard']")));
        assertTrue(driver.getCurrentUrl().contains("/customer"),
                "Expected to remain on /customer after page refresh (session should persist)");
    }

    // ── Test 5: Unauthorized Direct Access Protection (FR-AU3) ───────────────

    @Test
    @DisplayName("E2E-AU-5: Accessing /customer without login should redirect to /login")
    void unauthorizedAccess_shouldRedirectToLogin() {
        // Act — navigate directly to the protected dashboard without any login
        driver.get(BASE_URL + "/customer");

        // Assert — the middleware forces a redirect to /login
        wait.until(ExpectedConditions.urlContains("/login"));
        assertTrue(driver.getCurrentUrl().contains("/login"),
                "Expected unauthenticated user to be redirected to /login");

        // Assert — confirm the login form is present (not just any /login URL)
        assertTrue(
                driver.findElement(By.cssSelector("[data-testid='login-email']")).isDisplayed(),
                "Expected login form to be visible after unauthorized redirect"
        );
    }
}
